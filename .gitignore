venv/
env/
ENV/
.venv/

# 构建产物
dist/
build/
out/
*.exe
*.dll
*.so
*.dylib

# 运行时数据
data/
!frontend/src/data/
!frontend/src/data/learning/
!frontend/src/data/learning/langchainCurriculum.ts
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# 环境变量
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# 测试覆盖率
coverage/
.nyc_output

# 临时文件
tmp/
temp/
*.tmp
*.temp

# 备份文件
*.bak
*.backup
*.old

# 文档生成
docs/_build/
docs/_site/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 缓存文件
.cache/
.parcel-cache/

# 包管理器锁文件
package-lock.json
yarn.lock
pnpm-lock.yaml

# 配置文件（包含敏感信息）
config/local.yaml
config/development.yaml
config/staging.yaml
config/production.yaml

# 证书和密钥
*.pem
*.key
*.crt
*.csr

# 大文件
*.zip
*.tar.gz
*.rar
*.7z

# 镜像文件
*.iso
*.img

# 媒体文件
*.mp4
*.avi
*.mov
*.mp3
*.wav

