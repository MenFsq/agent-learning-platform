# 数据库配置
DATABASE_URL=postgresql://postgres:970825@localhost:5432/agent_platform
DATABASE_TEST_URL=postgresql://postgres:970825@localhost:5432/agent_platform_test

# 安全配置
SECRET_KEY=replace-with-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI服务配置
# 统一后端 `start_unified.py` 会优先使用 DeepSeek 的 OpenAI 兼容接口。
DEEPSEEK_API_KEY=sk-b279e810adbb4e4c976132eef530621c
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEFAULT_CHAT_MODEL=deepseek-chat
DEFAULT_REASONER_MODEL=deepseek-reasoner

# 如果你仍然需要兼容 OpenAI，可额外配置以下变量。
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENCLAW_API_KEY=your-openclaw-api-key
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langchain-api-key
LANGCHAIN_PROJECT=agent-learning-platform

# 缓存配置
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# 应用配置
DEBUG=True
ENVIRONMENT=development
ALLOWED_HOSTS=*
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 邮件配置（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@agent-learning-platform.com

# 文件存储
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760  # 10MB

# 监控配置
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_PORT=9090