# 生产环境配置
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/agent_platform
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# 服务器配置
HOST=0.0.0.0
PORT=8000
WORKERS=4
THREADS=2

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:80,https://your-domain.com

# 会话配置
SESSION_SECRET=your-session-secret
SESSION_TIMEOUT=3600
COOKIE_SECURE=True
COOKIE_HTTPONLY=True

# 文件上传
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH=16 * 1024 * 1024  # 16MB
ALLOWED_EXTENSIONS=.txt,.pdf,.png,.jpg,.jpeg,.gif

# 邮件配置（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=noreply@agent-platform.com

# 监控配置
ENABLE_METRICS=True
METRICS_PORT=9090
HEALTH_CHECK_PATH=/health

# 缓存配置
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=agent_platform_

# 限流配置
RATE_LIMIT_ENABLED=True
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/1